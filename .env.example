# Persistence driver: inmemory (default — the service starts WITHOUT Postgres, nothing survives
# a restart; for dev/demo/boot tests) | prisma (PostgreSQL via DATABASE_URL, see docs/PERSISTENCE.md)
REPOSITORY_DRIVER=inmemory
DATABASE_URL=postgresql://clickwrap:clickwrap@localhost:5432/clickwrap  # only for REPOSITORY_DRIVER=prisma
# Legal-entities config (audiences + document types), reconciled into the store at boot. A missing or
# malformed file fails the boot. Defaults to config/legal-entities.json (see docs/PERSISTENCE.md).
# LEGAL_ENTITIES_CONFIG=config/legal-entities.json
# --- Plugins (see docs/PLUGINS.md) -------------------------------------------------------------
# Plugins are auto-discovered from installed dependencies (package.json "clickwrap" manifest) and
# from CLICKWRAP_PLUGIN_PATHS; activation is ALWAYS explicit via the env vars below.
CLICKWRAP_PLUGIN_PATHS=              # comma-separated local plugin dirs (development/fixtures); empty = none

# E-mail delivery provider (plugin key). Built-ins: postmark | smtp | noop.
EMAIL_PROVIDER=noop                  # default noop: logs, no real sending
EMAIL_FROM=                          # sender address; REQUIRED for postmark & smtp (no hardcoded fallback)

# Postmark (EMAIL_PROVIDER=postmark): the only provider with delivery tracking (webhook + polling).
POSTMARK_API_TOKEN=                  # empty = no real sending, fake providerRefs (webhook/polling stay wired)
POSTMARK_WEBHOOK_TOKEN=              # token header for POST /webhooks/postmark (403 on mismatch)

# SMTP (EMAIL_PROVIDER=smtp): send only, NO delivery tracking — deadlines then start via portal popup only.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false                    # true = implicit TLS (port 465)
SMTP_USER=                           # empty = no SMTP auth
SMTP_PASS=

# File storage for version PDFs (plugin key). Built-ins: memory | local.
FILE_STORAGE=memory                  # default memory: nothing survives a restart (dev/demo/tests)
# Local-disk storage (FILE_STORAGE=local): single-node only — use object storage for multi-node.
FILE_STORAGE_LOCAL_DIR=              # REQUIRED when local is active: directory for the blobs (created recursively)
FILE_STORAGE_LOCAL_SECRET=           # REQUIRED when local is active: HMAC secret for the time-limited /files links
# Absolute public base URL of this service (e.g. https://clickwrap.example.org). Used for /files
# links (empty = relative, same-origin only) and REQUIRED to mint hosted acceptance links
# (POST /admin/customers/:id/acceptance-links → ${PUBLIC_BASE_URL}/accept/<token>).
PUBLIC_BASE_URL=
# Brand name used in rollout/reminder e-mails (the {{appName}} template variable). Defaults to
# "clickwrap-server".
APP_NAME=
# Secret used to derive each customer's PERMANENT acceptance link (the {{acceptanceLink}} variable
# in rollout/reminder mails). REQUIRED in production — a dev fallback is used when unset, which
# makes the permanent links predictable. Rotating it invalidates all existing permanent links.
ACCEPTANCE_LINK_SECRET=

# Admin auth: ORDERED comma list of admin-auth plugin keys (first identity wins).
# Built-ins: google-sso | static-token | supertokens.
ADMIN_AUTH=google-sso,static-token
ADMIN_API_TOKEN=change-me            # static-token strategy (x-admin-token, dev/CI) — empty = disabled
SERVICE_API_TOKEN=change-me          # MVP stub: service-to-service auth of the tools

# google-sso strategy (the admin web UI fetches GET /admin/auth/methods and sends the Google ID
# token as Authorization: Bearer — the clientId comes from HERE, a frontend-side
# VITE_GOOGLE_CLIENT_ID is obsolete)
GOOGLE_CLIENT_ID=                    # OAuth 2.0 client ID (…apps.googleusercontent.com); empty = method not advertised, bearer path disabled
ADMIN_ALLOWED_DOMAIN=                # REQUIRED for the Google path: e-mail must end in @<domain>; empty = Google sign-in rejected (401)
ADMIN_ALLOWED_EMAILS=                # optional, comma-separated: exact allowlist in addition to the domain

# supertokens strategy (ADMIN_AUTH contains "supertokens"): JWKS-based session verification.
SUPERTOKENS_JWKS_URL=                # REQUIRED when active, e.g. https://st.example.org/auth/jwt/jwks.json
SUPERTOKENS_ISSUER=                  # optional: verify the iss claim when set
SUPERTOKENS_LOGIN_URL=               # optional: advertises an oidc-redirect login method; empty = verify-only
ADMIN_SUPERTOKENS_ROLE=admin         # required role in the st-role claim (UserRoles recipe)
# Comma-separated CORS origins of the admin UI; empty = CORS off (a bootstrap warning is logged).
# Both admin-ui dev ports are listed: 5173 = `vite dev`, 4173 = `vite preview`.
ADMIN_UI_ORIGINS=http://localhost:5173,http://localhost:4173
SWEEPER_ENABLED=true                 # sweeper kill switch
PORT=3000
OPENAPI_DOCS_ENABLED=false           # true = serve Swagger UIs at /docs/admin and /docs/integration
