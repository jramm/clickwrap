# Base URL of the clickwrap-server backend
VITE_API_URL=http://localhost:3000

# DEPRECATED: the login screen now discovers methods (incl. the Google client ID)
# from GET /admin/auth/methods. VITE_GOOGLE_CLIENT_ID is only a legacy fallback
# used when that endpoint is unavailable (older backend). Leave unset otherwise.
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Brand name shown in the AppBar, page title and login screen (optional).
# Defaults to "clickwrap-server".
VITE_APP_NAME=clickwrap-server

# Optional dev fallback: when set, the header `x-admin-token` is added to all
# API calls (backend dev stub, while internal SSO is not yet enforced).
# Do NOT set this in production.
VITE_DEV_ADMIN_TOKEN=
