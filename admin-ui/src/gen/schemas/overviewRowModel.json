{
  "type": "object",
  "properties": {
    "customerId": { "type": "string", "example": "c-8a71…" },
    "customerName": {
      "type": "string",
      "example": "Acme GmbH",
      "description": "Derived display name: companyName if set, else the contact person's name ('' when unknown)."
    },
    "roles": { "example": ["customer"], "type": "array", "items": { "type": "string" } },
    "cells": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "acceptedVersion": { "type": "string", "example": "April 2026 edition" },
          "method": { "type": "string", "enum": ["ACTIVE_CONSENT", "TACIT", "IMPORT"] },
          "state": {
            "type": "string",
            "enum": [
              "PENDING_NOTIFICATION",
              "NOTIFIED",
              "ACCEPTED",
              "OBJECTED",
              "EXPIRED_BLOCKING",
              "SUPERSEDED"
            ]
          },
          "requiredVersion": {
            "type": "string",
            "example": "June 2026 edition",
            "description": "Only set while the current version is not accepted."
          },
          "deadlineAt": { "type": "string", "format": "date-time" },
          "blocking": { "type": "boolean" }
        },
        "required": ["blocking"],
        "x-readme-ref-name": "OverviewCellModel"
      },
      "description": "One cell per TYPE_AUDIENCE detail key (e.g. DPA_CUSTOMER)."
    }
  },
  "required": ["customerId", "customerName", "roles", "cells"],
  "x-readme-ref-name": "OverviewRowModel"
}
