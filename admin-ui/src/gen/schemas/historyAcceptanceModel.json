{
  "type": "object",
  "properties": {
    "versionId": { "type": "string" },
    "documentType": { "type": "string", "example": "dpa" },
    "versionLabel": { "type": "string", "example": "June 2026 edition" },
    "method": { "type": "string", "enum": ["ACTIVE_CONSENT", "TACIT", "IMPORT"] },
    "channel": { "type": "string", "enum": ["PORTAL", "ADMIN", "SYSTEM", "LINK"] },
    "acceptedAt": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "properties": {
        "userId": { "type": "string", "example": "u-42" },
        "name": { "type": "string", "example": "Jane Doe" },
        "email": { "type": "string", "example": "jane@customer.example" },
        "portalRole": { "type": "string", "example": "admin" }
      },
      "required": ["userId"],
      "x-readme-ref-name": "ActorModel"
    },
    "isEffective": { "type": "boolean" },
    "evidence": {
      "type": "object",
      "properties": {
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "consentText": { "type": "string" },
        "consentTextHash": { "type": "string", "example": "sha256:…" },
        "contentHash": { "type": "string", "example": "sha256:…" },
        "evidenceNote": {
          "type": "string",
          "example": "HubSpot deal 12345 / signed offer",
          "description": "IMPORT only."
        }
      },
      "x-readme-ref-name": "HistoryEvidenceModel"
    }
  },
  "required": ["versionId", "method", "channel", "acceptedAt", "actor", "isEffective", "evidence"],
  "x-readme-ref-name": "HistoryAcceptanceModel"
}
