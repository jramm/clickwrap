{
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "v-4f9f6a…" },
          "documentId": { "type": "string", "example": "doc-1c2d…" },
          "versionLabel": { "type": "string", "example": "June 2026 edition" },
          "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "RETIRED"] },
          "acceptanceMode": { "type": "string", "enum": ["ACTIVE", "PASSIVE"] },
          "changeSummary": {
            "type": "string",
            "example": "New sub-processor for e-mail delivery."
          },
          "consentText": {
            "type": "string",
            "description": "Exact checkbox consent text (ACTIVE only)."
          },
          "objectionPeriodDays": {
            "type": "number",
            "example": 14,
            "description": "PASSIVE only: objection period in days."
          },
          "objectionConsequence": {
            "type": "string",
            "example": "If you object, your existing terms remain in force and we may contact you about the change.",
            "description": "PASSIVE only: shown on the acceptance page next to the objection button."
          },
          "gracePeriodDays": {
            "type": "number",
            "example": 14,
            "description": "Deprecated: no longer drives ACTIVE blocking (legacy rows only)."
          },
          "hardDeadlineAt": {
            "type": "string",
            "format": "date-time",
            "description": "ACTIVE only: absolute acceptance deadline. Every customer must accept by then or is blocked, independent of access."
          },
          "validFrom": { "type": "string", "format": "date-time" },
          "publishedAt": { "type": "string", "format": "date-time" },
          "contentHash": {
            "type": "string",
            "example": "sha256:9c1e…",
            "description": "SHA-256 of the PDF content."
          },
          "fileName": { "type": "string", "example": "dpa-2026-06.pdf" },
          "pdfUrl": {
            "type": "string",
            "description": "Presigned, time-limited PDF download/preview URL (15-minute TTL)."
          }
        },
        "required": [
          "id",
          "documentId",
          "versionLabel",
          "status",
          "acceptanceMode",
          "changeSummary",
          "validFrom",
          "contentHash",
          "fileName",
          "pdfUrl"
