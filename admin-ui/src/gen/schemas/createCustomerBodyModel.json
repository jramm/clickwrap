{
  "type": "object",
  "properties": {
    "externalRef": { "type": "string", "example": "crm-4711" },
    "firstName": {
      "type": "string",
      "example": "Jane",
      "description": "Contact person's given name."
    },
    "lastName": {
      "type": "string",
      "example": "Doe",
      "description": "Contact person's family name."
    },
    "companyName": {
      "type": "string",
      "example": "Acme GmbH",
      "description": "Optional company/organisation name."
    },
    "roles": {
      "example": ["customer"],
      "description": "Audience keys (validated).",
      "type": "array",
      "items": { "type": "string" }
    },
    "contactEmails": {
      "example": ["legal@acme.example"],
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptedVersions": {
      "description": "Versions already accepted out-of-band (signed offer) — recorded as IMPORT acceptances.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "versionId": { "type": "string", "example": "v-4f9f6a…" },
          "acceptedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Signature date; backdating is allowed for IMPORT. Defaults to now."
          },
          "reference": {
            "type": "string",
            "example": "HubSpot deal 12345 / signed offer",
            "description": "Evidence reference."
          }
        },
        "required": ["versionId"],
        "x-readme-ref-name": "AcceptedVersionImportModel"
      }
    },
    "signedDocuments": {
      "description": "Accept documents by type at a signing date: the version of each listed document type that was effective at effectiveDate is recorded as an IMPORT acceptance (#29).",
      "allOf": [
        {
          "type": "object",
          "properties": {
            "effectiveDate": {
              "type": "string",
              "format": "date-time",
              "description": "Contract signing date — the version of each listed type effective at this date is accepted."
            },
            "documentTypes": {
              "example": ["terms", "dpa"],
              "description": "Document type keys the contract covers.",
              "type": "array",
              "items": { "type": "string" }
            },
            "reference": {
              "type": "string",
              "example": "Signed offer / CRM deal 12345",
              "description": "Evidence reference."
            }
          },
          "required": ["effectiveDate", "documentTypes"],
          "x-readme-ref-name": "SignedDocumentsModel"
        }
      ]
    }
  },
  "required": ["externalRef", "roles", "contactEmails"],
  "x-readme-ref-name": "CreateCustomerBodyModel"
}
